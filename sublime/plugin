#!/usr/bin/env python3
import argparse
import os
import sys
from pathlib import Path

PLUGINS_DIR = Path(__file__).resolve().parent / "plugins"
PACKAGES_DIR = Path.home() / ".config" / "sublime-text" / "Packages"


def main():
    parser = argparse.ArgumentParser(description="Manage Sublime Text plugin symlinks")
    sub = parser.add_subparsers(dest="command", required=True)

    for cmd in ("install", "remove"):
        p = sub.add_parser(cmd)
        p.add_argument("-a", "--all", action="store_true", help="Apply to all plugins")
        p.add_argument("plugins", nargs="*", help="Plugin names")

    sub.add_parser("list")

    args = parser.parse_args()

    if args.command == "list":
        for name in list_plugins():
            installed = (PACKAGES_DIR / name).is_symlink()
            status = " (installed)" if installed else ""
            print(f"  {name}{status}")
        return

    plugins = resolve_plugins(args)
    handler = {"install": install, "remove": remove}[args.command]
    errors = handler(plugins)
    if errors:
        sys.exit(1)


def resolve_plugins(args: argparse.Namespace) -> list[str]:
    if args.all:
        return list_plugins()
    if not args.plugins:
        print("error: no plugins specified (use -a/--all or provide plugin names)", file=sys.stderr)
        sys.exit(1)
    return args.plugins


def install(plugins: list[str]) -> int:
    PACKAGES_DIR.mkdir(parents=True, exist_ok=True)
    errors = 0
    for name in plugins:
        source = PLUGINS_DIR / name
        target = PACKAGES_DIR / name
        if not source.is_dir():
            print(f"  error: plugin '{name}' not found in {PLUGINS_DIR}", file=sys.stderr)
            errors += 1
            continue
        if target.is_symlink():
            print(f"  {name} (already installed)")
        elif target.exists():
            print(f"  error: {target} exists and is not a symlink, skipping", file=sys.stderr)
            errors += 1
        else:
            target.symlink_to(source)
            print(f"  {name} (installed)")
    return errors


def remove(plugins: list[str]) -> int:
    errors = 0
    for name in plugins:
        target = PACKAGES_DIR / name
        if target.is_symlink():
            target.unlink()
            print(f"  {name} (removed)")
        elif target.exists():
            print(f"  error: {target} is not a symlink, refusing to remove", file=sys.stderr)
            errors += 1
        else:
            print(f"  {name} (not installed)")
    return errors


def list_plugins() -> list[str]:
    return sorted(d.name for d in PLUGINS_DIR.iterdir() if d.is_dir())


if __name__ == "__main__":
    main()
