[alias]
	b = branch
	s = status
	graph = log --graph --decorate --color
	oops = commit --amend
	oneline = log --oneline --decorate --color
    o = log --oneline --decorate --color
	adog = log --all --decorate --oneline --graph
	dog = log --decorate --oneline --graph
	dateline = log --pretty=format:"%C(yellow)%h %Cblue%>(12)%ad %Cgreen%<(7)%aN%Cred%d %Creset%s"
	recent = !git reflog | grep \"checkout: moving from\" | awk '{print $NF}' | awk '!seen[$0]++' | head -20
[push]
	default = simple
[user]
	name = Jack Smith
	email = jack.je.smith@gmail.com
[core]
	excludesFile = /home/jack/.gitignore_global
	editor = vim
[pull]
	ff = only
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultBranch = main
